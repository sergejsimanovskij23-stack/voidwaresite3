{
  "builds": [
    {
      "src": "src/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/src/pages/index.html"
    },
    {
      "source": "/:page",
      "destination": "/src/pages/:page.html"
    }
  ],
  "routes": [
    {
      "src": "/src/data/(.*)",
      "status": 404,
      "dest": "/404.html"
    },
    {
      "src": "/(.*)\\.txt",
      "status": 404,
      "dest": "/404.html"
    }
  ]
}
